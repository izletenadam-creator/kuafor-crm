# ── Google Places API (zorunlu — lead aramak için) ──
# https://console.cloud.google.com → Places API'yi etkinleştir
GOOGLE_PLACES_API_KEY=

# ── Ollama (yerel AI — ücretsiz) ──
# Kurulum: https://ollama.com → ollama pull mistral:7b
OLLAMA_URL=http://localhost:11434/v1/chat/completions
OLLAMA_MODEL=mistral:7b

# ── WAHA (WhatsApp HTTP API — mesaj göndermek için) ──
# Kurulum: docker run -p 3000:3000 devlikeapro/waha
WAHA_URL=http://localhost:3000
WAHA_API_KEY=

# ── Telegram (bildirim — isteğe bağlı) ──
# @BotFather ile bot oluştur
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# ── CRM Klasörü (isteğe bağlı — varsayılan: script'in bulunduğu klasör) ──
# CRM_DIR=/home/kullanici/kuafor-crm

# ── Git ──
GIT_TOKEN=
